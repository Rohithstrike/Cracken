# =============================================================
# SOC Log Parser — Environment Configuration Template
# Copy this file to .env and fill in your values
# cp .env.example .env
# =============================================================

# ----- Application -----
APP_ENV=development
# Options: development | production | testing
# In development: verbose logs, API docs enabled, CORS open
# In production:  JSON logs, API docs disabled, CORS restricted

LOG_LEVEL=INFO
# Options: DEBUG | INFO | WARNING | ERROR

# ----- File Handling -----
MAX_FILE_SIZE_MB=50
# Maximum size of uploaded log files in megabytes

ALLOWED_EXTENSIONS=.log,.txt
# Comma-separated list of accepted file extensions

# ----- AI Provider -----
AI_PROVIDER=ollama
# Options: ollama | openai | claude
# Switch here — no code changes required

# Ollama (local, used during development)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
# Recommended models: mistral | llama3 | deepseek-coder

# OpenAI (production option — leave blank if not using)
OPENAI_API_KEY=

# Claude / Anthropic (production option — leave blank if not using)
CLAUDE_API_KEY=

# ----- Regex Engine -----
SAMPLE_LINE_COUNT=20
# Number of log lines sampled for pattern detection and AI analysis
# Higher = more accurate detection, slightly slower